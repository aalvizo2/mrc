<!DOCTYPE html>
<html>

<head>
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link rel="shortcut icon" href="img/favicon.png" sizes="150x150" />
    <title>Mensajes</title>
    <link rel="stylesheet" href="css/navbar-admin.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css"
        integrity="sha384-b6lVK+yci+bfDmaY1u0zE8YYJt0TZxLEAFyYSLHId4xoVvsrQu3INevFKo+Xir8e" crossorigin="anonymous">
    <link rel="stylesheet" href="css/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100&family=Quicksand&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-aFq/bzH65dt+w6FI2ooMVUpc+21e0SRygnTpmBvdBgSdnuTN7QbdgL+OapgHtvPp" crossorigin="anonymous">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <script src="https://kit.fontawesome.com/5210f6d31f.js" crossorigin="anonymous"></script>
    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            display: flex;
            height: 100vh;
            background: #f4f6f9;
        }

        /* SIDEBAR USUARIOS */
        #sidebar {
            margin-left: 240px;
            width: 300px;
            background: linear-gradient(180deg, #b30000, #7a0000);
            color: white;
            overflow-y: auto;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.2);
        }

        .user {
            padding: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            transition: 0.2s;
        }

        .user:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .active {
            background: rgba(0, 0, 0, 0.3);
        }

        .preview {
            font-size: 12px;
            opacity: 0.8;
        }

        /* CHAT */
        #chat-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            margin-top: 100px;
        }

        #chat-container.admin-view {
            margin-top: 0;
        }

        /* MENSAJES */
        #messages {
            flex: 1;
            padding: 20px;
            background: #e5ddd5;
            overflow-y: auto;
        }

        /* BURBUJAS */
        .msg {
            padding: 12px 15px;
            margin: 8px 0;
            border-radius: 12px;
            max-width: 60%;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            font-size: 14px;
        }

        .me {
            background: #dcf8c6;
            margin-left: auto;
        }

        .other {
            background: white;
        }

        /* TEXTO EXTRA */
        .msg small {
            display: block;
            font-size: 10px;
            margin-top: 5px;
            color: #555;
        }

        /* INPUT */
        #form {
            display: flex;
            padding: 10px;
            background: white;
            border-top: 1px solid #ddd;
        }

        #input {
            flex: 1;
            padding: 12px;
            border-radius: 20px;
            border: 1px solid #ccc;
            outline: none;
        }

        /* BOTÓN */
        .chat-btn {
            margin-left: 10px;
            padding: 10px 20px;
            background: #b30000;
            color: white;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            transition: 0.2s;
        }

        .chat-btn :hover {
            background: #7a0000;
        }

        .top {
            width: 100%;
            height: 150px;
        }

        /* 📱 RESPONSIVE */
        @media (max-width: 768px) {

            body {
                flex-direction: column;
                height: 100vh;
                overflow: hidden;
            }

            /* sidebar rojo (navbar admin) */
            .sidebar {
                position: relative;
                width: 100%;
                height: auto;
            }

            /* sidebar usuarios */
            #sidebar {
                margin-left: 0;
                width: 100%;
                height: calc(100vh - 60px);
                overflow-y: auto;
                display: block;
            }

            /* chat oculto por default */
            #chat-container {
                display: none;
                width: 100%;
                height: calc(100vh - 60px);
            }

            /* cuando está activo */
            #chat-container.active {
                display: flex;
                flex-direction: column;
            }

            #messages {
                flex: 1;
                padding: 10px;
            }

            .msg {
                max-width: 85%;
                font-size: 13px;
            }

            #form {
                padding: 8px;
            }

            #input {
                padding: 10px;
                font-size: 14px;
            }

            .chat-btn {
                padding: 8px 12px;
                font-size: 14px;
            }

            /* botón regresar */
            .back-btn {
                padding: 10px;
                background: #b30000;
                color: white;
                border: none;
                width: 100%;
                text-align: left;
            }
        }
    </style>
</head>

<body>
    <% if (admin) { %>
        <%- include('./components/navbarAdmin') %>
            <% } %>

                <% if (usuario) { %>
                    <%- include('./components/header') %>

                        <% } %>

                            <div id="sidebar"></div>

                            <div id="chat-container" class="<%= administrador ? 'admin-view' : '' %>">
                                <button id="backBtn" class="back-btn d-none">← Regresar</button>
                                <div id="messages"></div>

                                <form id="form">
                                    <input id="input" placeholder="Escribe..." autocomplete="off" />
                                    <button type="submit" class="chat-btn">Enviar</button>
                                </form>
                            </div>

                            <script>
                                const USUARIO = "<%= usuario || '' %>";
                                const ES_ADMIN = <%= esAdmin ? 'true' : 'false' %>;
                                const administrador = "<%= admin %>";
                            </script>

                            <script src="/socket.io/socket.io.js"></script>

                            <script>
                                const socket = io();

                                const sidebar = document.getElementById('sidebar');
                                const messages = document.getElementById('messages');
                                const form = document.getElementById('form');
                                const input = document.getElementById('input');

                                let usuarioActivo = null;
                                let conversaciones = {};
                                let usuariosAgregados = new Set();

                                // ocultar sidebar si es usuario
                                if (!ES_ADMIN) {
                                    sidebar.style.display = 'none';
                                    document.getElementById('chat-container').style.width = '100%';
                                }

                                // CONEXIÓN
                                socket.on('connect', () => {
                                    console.log('Conectado:', socket.id);
                                });

                                // RECIBIR MENSAJES
                                socket.on('mensaje', (msg) => {

                                    if (!msg || !msg.texto) return;

                                    if (ES_ADMIN) {

                                        if (!conversaciones[msg.usuario]) {
                                            conversaciones[msg.usuario] = [];
                                        }

                                        conversaciones[msg.usuario].push(msg);

                                        if (!usuariosAgregados.has(msg.usuario)) {
                                            agregarUsuario(msg.usuario);
                                            usuariosAgregados.add(msg.usuario);
                                        }

                                        actualizarPreview(msg);

                                        if (usuarioActivo === msg.usuario) {
                                            pintar(msg);
                                        }

                                    } else {
                                        pintar(msg);
                                    }
                                });

                                // AGREGAR USUARIO
                                function agregarUsuario(usuario) {
                                    const div = document.createElement('div');
                                    div.classList.add('user');
                                    div.id = `user-${usuario}`;

                                    div.innerHTML = `
        <strong>${usuario}</strong>
        <div class="preview" id="preview-${usuario}">Sin mensajes</div>
    `;

                                    div.onclick = () => {
                                        usuarioActivo = usuario;
                                        messages.innerHTML = '';

                                        conversaciones[usuario].forEach(pintar);

                                        document.querySelectorAll('.user').forEach(u => u.classList.remove('active'));
                                        div.classList.add('active');
                                    };

                                    sidebar.appendChild(div);
                                }

                                // ACTUALIZAR PREVIEW
                                function actualizarPreview(msg) {
                                    const preview = document.getElementById(`preview-${msg.usuario}`);
                                    if (preview) {
                                        preview.textContent = msg.texto;
                                    }
                                }

                                // PINTAR MENSAJE
                                function pintar(msg) {
                                    const div = document.createElement('div');
                                    div.classList.add('msg');

                                    if (ES_ADMIN) {
                                        div.classList.add(msg.tipo === 'admin' ? 'me' : 'other');
                                    } else {
                                        div.classList.add(msg.tipo === 'usuario' ? 'me' : 'other');
                                    }

                                    div.innerHTML = `
        <div>${msg.texto}</div>
        <small>${msg.hora}</small>
        <small>${msg.tipo === 'admin' ? administrador : msg.usuario}</small>
    `;

                                    messages.appendChild(div);
                                    messages.scrollTop = messages.scrollHeight;
                                }

                                // ENVIAR MENSAJE
                                form.addEventListener('submit', (e) => {
                                    e.preventDefault();

                                    if (!input.value.trim()) return;

                                    let data;

                                    if (ES_ADMIN) {
                                        if (!usuarioActivo) {
                                            alert('Selecciona un usuario');
                                            return;
                                        }

                                        data = {
                                            texto: input.value,
                                            usuario: usuarioActivo,
                                            tipo: 'admin'
                                        };

                                    } else {
                                        data = {
                                            texto: input.value,
                                            usuario: USUARIO,
                                            tipo: 'usuario'
                                        };
                                    }

                                    socket.emit('mensaje', data);
                                    input.value = '';
                                });

                                // CARGAR HISTORIAL
                                socket.emit('historial', {
                                    usuario: USUARIO ? USUARIO : 'MRC',
                                    tipo: ES_ADMIN ? 'admin' : 'usuario'
                                });

                                socket.on('historial', (data) => {

                                    if (ES_ADMIN) {

                                        data.forEach(msg => {

                                            if (!conversaciones[msg.usuario]) {
                                                conversaciones[msg.usuario] = [];
                                            }

                                            conversaciones[msg.usuario].push(msg);

                                            if (!usuariosAgregados.has(msg.usuario)) {
                                                agregarUsuario(msg.usuario);
                                                usuariosAgregados.add(msg.usuario);
                                            }

                                            actualizarPreview(msg);
                                        });

                                    } else {
                                        data.forEach(pintar);
                                    }
                                });


                                const params = new URLSearchParams(window.location.search)
                                const usuarioFromURL = params.get('user')

                                if (usuarioFromURL) {
                                    usuarioActivo = usuarioFromURL

                                    // simular click en el usuario
                                    setTimeout(() => {
                                        const userDiv = document.getElementById(`user-${usuarioFromURL}`)
                                        if (userDiv) userDiv.click()
                                    }, 500)
                                }

                                const chatContainer = document.getElementById('chat-container')
                                const backBtn = document.getElementById('backBtn')


                                div.onclick = () => {
                                    usuarioActivo = usuario;
                                    messages.innerHTML = '';

                                    conversaciones[usuario].forEach(pintar);

                                    document.querySelectorAll('.user').forEach(u => u.classList.remove('active'));
                                    div.classList.add('active');

                                    // 🔥 MOBILE: cambiar vista
                                    if (window.innerWidth < 768) {
                                        sidebar.style.display = 'none'
                                        chatContainer.style.display = 'flex'
                                        chatContainer.classList.add('active')
                                        backBtn.classList.remove('d-none')
                                    }
                                };

                                backBtn.addEventListener('click', () => {
                                    sidebar.style.display = 'block'
                                    chatContainer.style.display = 'none'
                                    chatContainer.classList.remove('active')
                                    backBtn.classList.add('d-none')
                                })
                            </script>
                            <script src="script/responsive.js"></script>

</body>

</html>