<div id="panelNotificaciones" class="panel-notif d-none">
    <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
        <h6 class="m-0">Notificaciones</h6>
        <i class="bi bi-x-lg cerrar-notif"></i>
    </div>
    <div id="contenidoNotif"></div>
</div>


<script>
    let ultimaCantidad = 0 // 🔥 para detectar nuevas

    function toggleNotificaciones() {
        const panel = document.getElementById('panelNotificaciones')
        panel.classList.toggle('d-none')
    }

    function cargarNotificaciones() {

        Promise.all([
            fetch('/stock-bajo').then(r => r.json()),
            fetch('/chat').then(r => r.json()).catch(() => [])
        ])
            .then(([stock, chat]) => {

                const cont = document.getElementById('contenidoNotif')
                const badge = document.getElementById('badgeNotif')

                cont.innerHTML = ''
                let total = 0

                // 🔴 STOCK
                stock.forEach(p => {
                    cont.innerHTML = `
                <div class="notif-item text-danger">
                    ⚠️ ${p.producto} (${p.cantidad})
                </div>
            ` + cont.innerHTML
                    total++
                })

                // SOLO MENSAJES DE CLIENTES
                const mensajesCliente = chat.filter(m => m.tipo === 'usuario')

                mensajesCliente.slice(0, 5).forEach(m => {
                    cont.innerHTML = `
                <div class="notif-item">
                    💬 ${m.usuario}: ${m.mensaje}
                    <button onclick="responder('${m.usuario}')" class="view-btn">Ver</button>
                </div>
            ` + cont.innerHTML

                    total++
                })

                // 🔔 BADGE
                if (total > 0) {
                    badge.innerText = total
                    badge.style.display = 'inline-block'
                } else {
                    badge.style.display = 'none'
                }

                // 🔥 DETECTAR NUEVAS (opcional)
                if (total > ultimaCantidad) {
                    console.log('🔔 Nueva notificación')
                }

                ultimaCantidad = total
            })
    }

    // 🔥 REDIRECCIÓN
    function responder(usuario) {
        window.location.href = `/chat-test?user=${usuario}`
    }

    // 🔥 AUTO CARGA
    cargarNotificaciones()
    setInterval(cargarNotificaciones, 800)
</script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const panel = document.getElementById("panelNotificaciones")
        document.body.appendChild(panel) // 🔥 lo saca de cualquier contenedor roto
    })

    //Cerrar notificaciones
    document.addEventListener("click", (e) => {
    if (e.target.classList.contains("cerrar-notif")) {
        document.getElementById("panelNotificaciones").classList.add("d-none")
    }
})
</script>