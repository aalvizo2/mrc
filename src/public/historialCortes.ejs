<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Historial de Cortes</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="img/favicon.png" sizes="150x150" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="css/inventario.css">
    <link rel="stylesheet" href="css/navbar-admin.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css"
        integrity="sha384-b6lVK+yci+bfDmaY1u0zE8YYJt0TZxLEAFyYSLHId4xoVvsrQu3INevFKo+Xir8e" crossorigin="anonymous">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100&family=Quicksand&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-aFq/bzH65dt+w6FI2ooMVUpc+21e0SRygnTpmBvdBgSdnuTN7QbdgL+OapgHtvPp" crossorigin="anonymous">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <script src="https://kit.fontawesome.com/5210f6d31f.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f6f9;
        }

        /* Respeta sidebar */
        .content {
            margin-left: 260px;
            padding: 30px;
        }

        .title {
            font-weight: 700;
        }

        .card-pro {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        }

        .table {
            border-radius: 10px;
            overflow: hidden;
        }

        .badge-success {
            background: #28a745;
        }

        .badge-danger {
            background: #dc3545;
        }

        .modal-content {
            border-radius: 15px;
        }



        @media (max-width: 768px) {

            /* layout general */
            .content {
                margin-left: 0;
                padding: 10px;
            }

            .title {
                font-size: 20px;
                text-align: center;
            }

            /* 🔥 TABLA: que no se rompa */
            .card-pro {
                overflow-x: auto;
            }

            table {
                min-width: 600px;
                /* fuerza scroll en vez de romper */
                font-size: 13px;
            }

            /* 🔥 MODAL más cómodo */
            .modal-dialog {
                margin: 10px;
            }

            /* 🔥 VENTAS (NO rompemos estructura) */
            #listaVentas .row {
                display: flex;
                flex-wrap: wrap;
            }

            #listaVentas .col-4 {
                flex: 0 0 100%;
                max-width: 100%;
                text-align: left !important;
                margin-bottom: 5px;
            }

            #listaVentas button {
                width: 100% !important;
            }

            /* 🔥 GASTOS */
            #listaGastos li {
                font-size: 14px;
            }

            /* 🔥 DETALLE VENTA */
            #detalleVenta .d-flex {
                flex-direction: column;
                align-items: flex-start !important;
            }
        }
    </style>
</head>

<body>

    <%- include('./components/navbarAdmin') %>

        <div class="content">

            <h2 class="title mb-4">Historial de Cortes</h2>

            <div class="card card-pro p-4">

                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Fecha</th>
                            <th>Ventas</th>
                            <th>Gastos</th>
                            <th>Diferencia</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody id="tablaCortes"></tbody>
                </table>

            </div>

        </div>

        <!-- 🔥 MODAL -->
        <div class="modal fade" id="modalDetalle">
            <div class="modal-dialog modal-lg">
                <div class="modal-content p-4">

                    <h4 class="mb-3">Detalle del Corte</h4>

                    <!-- INFO -->
                    <div id="infoCorte" class="mb-3"></div>

                    <!-- VENTAS -->
                    <h5>Ventas</h5>
                    <ul id="listaVentas" class="list-group mb-3"></ul>

                    <!-- GASTOS -->
                    <h5>Gastos</h5>
                    <ul id="listaGastos" class="list-group"></ul>
                    <div id="detalleVenta" class="mt-3"></div>
                </div>

            </div>
        </div>



        <script>
            // Dar formato a MXN 
            function formatoMoneda(valor) {
                return new Intl.NumberFormat('es-MX', {
                    style: 'currency',
                    currency: 'MXN'
                }).format(valor)
            }

            // 🔥 CARGAR HISTORIAL
            fetch('/corte-caja')
                .then(res => res.json())
                .then(data => {
                    const tabla = document.getElementById('tablaCortes')
                    tabla.innerHTML = '' // limpiar antes

                    data.forEach(c => {

                        const color = c.diferencia < 0 ? 'text-danger' : 'text-success'

                        tabla.innerHTML += `
                    <tr>
                        <td>${c.id}</td>
                        <td>${new Date(c.fecha).toLocaleString()}</td>
                        <td>${formatoMoneda(c.total_ventas)}</td>
                        <td>${formatoMoneda(c.total_gastos)}</td>
                        <td class="${color} fw-bold">
                            ${formatoMoneda(c.diferencia)}
                        </td>
                        <td>
                            <button onclick="verDetalle(${c.id})" 
                                class="btn btn-sm btn-dark">
                                Ver
                            </button>
                        </td>
                    </tr>
                `
                    })
                })


            function verDetalle(id) {

                fetch(`/detalle-corte/${id}`)
                    .then(res => res.json())
                    .then(data => {

                        const { corte, ventas, gastos } = data

                        // =========================
                        // INFO GENERAL
                        // =========================
                        document.getElementById('infoCorte').innerHTML = `
                <div class="row text-center">
                    <div class="col">
                        <h6>Ventas</h6>
                        <strong>${formatoMoneda(corte.total_ventas)}</strong>
                    </div>
                    <div class="col">
                        <h6>Gastos</h6>
                        <strong>${formatoMoneda(corte.total_gastos)}</strong>
                    </div>
                    <div class="col">
                        <h6>Diferencia</h6>
                        <strong class="${corte.diferencia < 0 ? 'text-danger' : 'text-success'}">
                            ${formatoMoneda(corte.diferencia)}
                        </strong>
                    </div>
                </div>
            `

                        // =========================
                        // VENTAS (OPTIMIZADO)
                        // =========================
                        const listaVentas = document.getElementById('listaVentas')

                        let htmlVentas = ''

                        for (let i = 0; i < ventas.length; i++) {
                            const v = ventas[i]

                            htmlVentas += `
                    <li class="list-group-item">
                        <div class="row align-items-center text-center">

                            <div class="col-4 text-start">
                                Venta No. ${v.id}
                            </div>

                            <div class="col-4">
                                <button class="btn btn-sm btn-default w-75"
                                    onclick="verDetalleVenta(${v.id})">
                                    Ver Detalle
                                </button>
                            </div>

                            <div class="col-4 text-end fw-bold">
                                ${formatoMoneda(v.total)}
                            </div>

                        </div>
                    </li>
                `
                        }

                        listaVentas.innerHTML = htmlVentas


                        // =========================
                        // GASTOS (OPTIMIZADO)
                        // =========================
                        const listaGastos = document.getElementById('listaGastos')

                        let htmlGastos = ''

                        for (let i = 0; i < gastos.length; i++) {
                            const g = gastos[i]

                            htmlGastos += `
                    <li class="list-group-item d-flex justify-content-between">
                        ${g.descripcion}
                        <span>${formatoMoneda(g.monto)}</span>
                    </li>
                `
                        }

                        listaGastos.innerHTML = htmlGastos


                        // =========================
                        // MODAL (OPEN LIGERO)
                        // =========================
                        const modalEl = document.getElementById('modalDetalle')
                        const modal = bootstrap.Modal.getOrCreateInstance(modalEl)

                        modal.show()
                    })
            }

            function verDetalleVenta(id) {

                fetch(`/detalle-venta/${id}`)
                    .then(res => res.json())
                    .then(data => {

                        const cont = document.getElementById('detalleVenta')

                        cont.innerHTML = `
                <div class="card p-3">
                    <h6>Detalle Venta No. ${id}</h6>

                    ${data.productos.map(p => `
                        <div class="d-flex justify-content-between">
                            <span>${p.nombre}</span>
                            <span>${formatoMoneda(p.precio)}</span>
                        </div>
                    `).join('')}

                    <hr>

                    <strong class="text-end d-block">
                        Total: ${formatoMoneda(data.total)}
                    </strong>
                </div>
            `
                    })
            }
        </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>