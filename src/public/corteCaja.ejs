<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="img/favicon.png" sizes="150x150" />
    <title>Corte de Caja</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="css/inventario.css">
    <link rel="stylesheet" href="css/navbar-admin.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css"
        integrity="sha384-b6lVK+yci+bfDmaY1u0zE8YYJt0TZxLEAFyYSLHId4xoVvsrQu3INevFKo+Xir8e" crossorigin="anonymous">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100&family=Quicksand&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-aFq/bzH65dt+w6FI2ooMVUpc+21e0SRygnTpmBvdBgSdnuTN7QbdgL+OapgHtvPp" crossorigin="anonymous">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <script src="https://kit.fontawesome.com/5210f6d31f.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f4f6f9;
        }

        /* RESPETA SIDEBAR */
        .content {
            margin-left: 260px;
            padding: 30px;
        }

        /* CARDS */
        .card-pro {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        }

        /* TITULOS */
        .title {
            font-weight: 700;
        }

        /* INPUTS */
        .form-control {
            border-radius: 10px;
        }

        /* BOTONES */
        .btn {
            border-radius: 10px;
        }

        /* DIFERENCIA */
        .positivo {
            color: #28a745;
        }

        .negativo {
            color: #dc3545;
        }

        /* 📱 MOBILE & TABLET FIX */
        @media (max-width: 992px) {

            .sidebar {
                position: relative;
                width: 100%;
                height: auto;
            }

            .content {
                margin-left: 0;
                /* 🔥 clave */
                padding: 15px;
            }

        }
    </style>
</head>

<body>

    <%- include('./components/navbarAdmin') %>

        <div class="content">

            <h2 class="mb-4 title">Corte de Caja</h2>

            <div class="row g-4">

                <!-- IZQUIERDA -->
                <div class="col-md-8">

                    <!-- APERTURA -->
                    <div class="card card-pro p-4 mb-4">
                        <h5 class="mb-3">Apertura de Caja</h5>
                        <input type="number" id="montoInicial" class="form-control" placeholder="Monto inicial">
                    </div>

                    <!-- GASTOS -->
                    <div class="card card-pro p-4">
                        <h5 class="mb-3">Gastos del turno</h5>

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <input type="text" id="descGasto" class="form-control" placeholder="Descripción">
                            </div>
                            <div class="col-md-4">
                                <input type="number" id="montoGasto" class="form-control" placeholder="Monto">
                            </div>
                            <div class="col-md-2">
                                <button class="btn btn-danger w-100" onclick="agregarGasto()">+</button>
                            </div>
                        </div>

                        <ul id="listaGastos" class="list-group"></ul>
                    </div>

                </div>

                <!-- DERECHA -->
                <div class="col-md-4">

                    <!-- RESUMEN -->
                    <div class="card card-pro p-4 mb-4">

                        <h5 class="mb-3">Resumen</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Ventas</span>
                            <strong><span id="totalVentas">0</span></strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Gastos</span>
                            <strong><span id="totalGastos">0</span></strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Caja inicial</span>
                            <strong><span id="showInicial">0</span></strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Caja chica</span>
                            <strong><span id="showCajaChica">0</span></strong>
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Total esperado</span>
                            <strong><span id="totalEsperado">0</span></strong>
                        </div>

                    </div>

                    <!-- CAJA CHICA -->
                    <div class="card card-pro p-3 mb-3">
                        <h6>Caja chica</h6>
                        <input type="number" id="cajaChica" class="form-control" placeholder="Monto caja chica">
                    </div>

                    <!-- DINERO REAL -->
                    <div class="card card-pro p-3 mb-3">
                        <h6>Dinero contado</h6>
                        <input type="number" id="dineroReal" class="form-control" placeholder="Efectivo real">
                    </div>

                    <!-- DIFERENCIA -->
                    <div class="card card-pro p-4 text-center mb-3">
                        <h6>Diferencia</h6>
                        <h2 id="diferencia">$0</h2>
                    </div>

                    <!-- BOTONES -->
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary" onclick="calcular()">Calcular</button>
                        <button class="btn btn-success" onclick="cerrarCorte()">Cerrar Corte</button>
                    </div>

                </div>

            </div>
        </div>

        <script>
            let gastos = []
            let totalVentas = 0
            let totalGastos = 0


            document.addEventListener('DOMContentLoaded', async () => {

                const [ventasRes, cajaRes] = await Promise.all([
                    fetch('/ventas-hoy'),
                    fetch('/caja-chica')
                ])

                const ventas = await ventasRes.json()
                const caja = await cajaRes.json()

                totalVentas = ventas.totalVentas || 0

                document.getElementById('totalVentas').innerText = formatoMoneda(totalVentas)

                document.getElementById('montoInicial').value = ventas.montoInicial || 0
                document.getElementById('showInicial').innerText = formatoMoneda(ventas.montoInicial || 0)

                const el = document.getElementById('showCajaChica')
                if (el) el.innerText = formatoMoneda(caja.cajaChica || 0)

                calcular()
            })

            //Formato moneda 
            function formatoMoneda(valor) {
                return new Intl.NumberFormat('es-MX', {
                    style: 'currency',
                    currency: 'MXN'
                }).format(valor)
            }


            // window.onload = () => {
            //     fetch('/ventas-hoy')
            //         .then(res => res.json())
            //         .then(data => {

            //             totalVentas = data.totalVentas || 0

            //             document.getElementById('totalVentas').innerText = formatoMoneda(totalVentas)

            //             // 🔥 AQUÍ pintas caja inicial
            //             document.getElementById('montoInicial').value = data.montoInicial || 0
            //             document.getElementById('showInicial').innerText = formatoMoneda(data.montoInicial || 0)

            //             calcular()
            //         })
            // }

            function agregarGasto() {
                const desc = document.getElementById('descGasto').value
                const monto = Number(document.getElementById('montoGasto').value)

                if (!desc || !monto) return

                gastos.push({ desc, monto })

                document.getElementById('descGasto').value = ''
                document.getElementById('montoGasto').value = ''

                renderGastos()
            }

            function renderGastos() {
                const lista = document.getElementById('listaGastos')
                lista.innerHTML = ''

                let total = 0
                totalGastos = total
                document.getElementById('totalGastos').innerText = formatoMoneda(total)
                gastos.forEach(g => {
                    total += g.monto

                    lista.innerHTML += `
        <li class="list-group-item d-flex justify-content-between">
            ${g.desc}
            <span>${formatoMoneda(g.monto)}</span>
        </li>`
                })

                document.getElementById('totalGastos').innerText = formatoMoneda(total)
            }

            function calcular() {
                const inicial = Number(document.getElementById('montoInicial').value) || 0
                const dineroReal = Number(document.getElementById('dineroReal').value) || 0

                document.getElementById('showInicial').innerText = formatoMoneda(inicial)

                const esperado = inicial + totalVentas - totalGastos
                const diferencia = dineroReal - esperado

                document.getElementById('totalEsperado').innerText = formatoMoneda(esperado)
                document.getElementById('diferencia').innerText = formatoMoneda(diferencia)

                const el = document.getElementById('diferencia')
                el.classList.remove('positivo', 'negativo')

                if (diferencia < 0) {
                    el.classList.add('negativo')
                } else {
                    el.classList.add('positivo')
                }
            }

            //toast de antd
            function notifySuccess(msg) {
                Toastify({
                    text: msg,
                    duration: 3000,
                    gravity: "top",
                    position: "center",
                    style: {
                        background: "#28a745"

                    }
                }).showToast();
            }

            function cerrarCorte() {
                const data = {
                    montoInicial: Number(document.getElementById('montoInicial').value),
                    gastos,
                    cajaChica: Number(document.getElementById('cajaChica').value),
                    dineroReal: Number(document.getElementById('dineroReal').value),
                    totalVentas
                }

                fetch('/corte-caja', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                })
                    .then(() => {
                        notifySuccess("Corte cerrado correctamente")
                        //Agregamos tiempo antes de recargar 
                        setTimeout(() => {
                            location.reload()
                        }, 1200)

                    })
            }
        </script>
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</body>

</html>