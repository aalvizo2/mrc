<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Administrador Carousel</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link rel="shortcut icon" href="img/favicon.png" sizes="150x150" />
    <title>Mensajes</title>
    <link rel="stylesheet" href="css/navbar-admin.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css"
        integrity="sha384-b6lVK+yci+bfDmaY1u0zE8YYJt0TZxLEAFyYSLHId4xoVvsrQu3INevFKo+Xir8e" crossorigin="anonymous">
    <link rel="stylesheet" href="css/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100&family=Quicksand&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-aFq/bzH65dt+w6FI2ooMVUpc+21e0SRygnTpmBvdBgSdnuTN7QbdgL+OapgHtvPp" crossorigin="anonymous">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <script src="https://kit.fontawesome.com/5210f6d31f.js" crossorigin="anonymous"></script>
    <style>
        body {
            background: #f4f6f9;
            font-family: 'Poppins', sans-serif;
        }

        .contenedor {
            padding: 40px;
        }

        .titulo {
            font-size: 30px;
            font-weight: bold;
            color: #111;
            margin-bottom: 30px;
        }

        .grid-carousel {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
        }

        .card-banner {
            position: relative;
            overflow: hidden;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
            cursor: pointer;
            background: white;
            transition: .3s ease;
        }

        .card-banner:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 35px rgba(0, 0, 0, .12);
        }

        .card-banner img {
            width: 100%;
            height: 240px;
            object-fit: cover;
            display: block;
        }

        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, .55);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 18px;
            opacity: 0;
            transition: .3s ease;
        }

        .card-banner:hover .overlay {
            opacity: 1;
        }

        .btn-icono {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            border: none;
            font-size: 22px;
            color: white;
            transition: .3s ease;
        }

        .editar {
            background: #0d6efd;
        }

        .editar:hover {
            transform: scale(1.12);
            background: #0b5ed7;
        }

        .eliminar {
            background: #dc3545;
        }

        .eliminar:hover {
            transform: scale(1.12);
            background: #bb2d3b;
        }

        .info {
            padding: 15px;
        }

        .info h5 {
            margin: 0;
            font-size: 16px;
            font-weight: 700;
        }

        .info p {
            margin: 0;
            color: gray;
            font-size: 14px;
        }

        .btn-subir {
            border-radius: 12px;
            padding: 10px 18px;
            font-weight: 600;
            margin-bottom: 25px;
        }
    </style>
</head>

<body>

    <%- include('./components/navbarAdmin') %>

        <div class="contenedor">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="titulo">Administrar Carousel</h1>

                <button class="btn btn-success btn-subir" onclick="seleccionarImagen()">
                    <i class="bi bi-plus-circle"></i>
                    Nueva Imagen
                </button>
            </div>

            <div class="grid-carousel" id="contenedorCarousel"></div>


            <input type="file" id="inputImagen" hidden accept="image/*">
        </div>


        <script>
            async function obtenerImagenes() {
                try {
                    const response = await fetch('/carousel')
                    const data = await response.json()

                    const contenedor = document.getElementById('contenedorCarousel')

                    contenedor.innerHTML = ''

                    data.forEach(item => {
                        contenedor.innerHTML += `
        <div class="card-banner">

          <img src="${item.imagen_url}" alt="banner">

          <div class="overlay">

            <button class="btn-icono editar"
              onclick="editarImagen(${item.id})">
              <i class="bi bi-pencil-fill"></i>
            </button>

            <button class="btn-icono eliminar"
              onclick="eliminarImagen(${item.id})">
              <i class="bi bi-trash-fill"></i>
            </button>

          </div>

          <div class="info">
            <h5>Banner #${item.id}</h5>
            <p>Orden: ${item.orden_num}</p>
          </div>

        </div>
      `
                    })

                } catch (error) {
                    console.error(error)
                }
            }

            function editarImagen(id) {
                alert('Editar imagen ID: ' + id)
            }

            function eliminarImagen(id) {
                const confirmar = confirm('¿Eliminar imagen?')

                if (!confirmar) return

                fetch('/carousel/' + id, {
                    method: 'DELETE'
                })
                    .then(res => res.json())
                    .then(data => {
                        alert(data.msg)
                        obtenerImagenes()
                    })
            }

            obtenerImagenes()



        </script>

        <script>
            window.onload = () => {

                const input = document.getElementById('inputImagen')

                input.addEventListener('change', async function () {

                    const archivo = this.files[0]

                    if (!archivo) return

                    const formData = new FormData()
                    formData.append('imagen', archivo)

                    const response = await fetch('/carousel', {
                        method: 'POST',
                        body: formData
                    })

                    const data = await response.json()

                    alert(data.msg || data.message)

                    obtenerImagenes()
                })

            }
        </script>

        <script>
            function seleccionarImagen() {
                document.getElementById('inputImagen').click()
            }
        </script>
</body>

</html>