<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administrador Carousel</title>
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <link rel="shortcut icon" href="img/favicon.png" sizes="150x150" />

    <link rel="stylesheet" href="css/navbar-admin.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css"
        integrity="sha384-b6lVK+yci+bfDmaY1u0zE8YYJt0TZxLEAFyYSLHId4xoVvsrQu3INevFKo+Xir8e" crossorigin="anonymous">
    <link rel="stylesheet" href="css/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100&family=Quicksand&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-aFq/bzH65dt+w6FI2ooMVUpc+21e0SRygnTpmBvdBgSdnuTN7QbdgL+OapgHtvPp" crossorigin="anonymous">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <script src="https://kit.fontawesome.com/5210f6d31f.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css">

    <style>
        body {
            background: #f4f6f9;
            font-family: Arial, Helvetica, sans-serif;
        }

        /* RESPETA TU SIDEBAR */
        .main-content {
            margin-left: 260px;
            padding: 30px;
        }

        @media(max-width:992px) {
            .main-content {
                margin-left: 0;
                padding: 15px;
            }
        }

        /* HEADER */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .title {
            font-size: 32px;
            font-weight: 700;
        }

        /* GRID */
        .grid-upload {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
            gap: 22px;
        }

        /* CARD IMAGEN */
        .card-img {
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0, 0, 0, .07);
            position: relative;
            transition: .25s;
        }

        .card-img:hover {
            transform: translateY(-5px);
        }

        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        /* INFO */
        .info {
            padding: 12px;
        }

        .info h6 {
            margin: 0;
            font-weight: 700;
        }

        .info p {
            margin: 0;
            color: #666;
            font-size: 14px;
        }

        /* OVERLAY */
        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, .55);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            opacity: 0;
            transition: .25s;
        }

        .card-img:hover .overlay {
            opacity: 1;
        }

        .btn-circle {
            width: 48px;
            height: 48px;
            border: none;
            border-radius: 50%;
            color: #fff;
            font-size: 20px;
        }

        .btn-edit {
            background: #0d6efd;
        }

        .btn-delete {
            background: #dc3545;
        }

        /* BOTON NUEVO */
        .upload-box {
            height: 250px;
            border: 2px dashed #d0d0d0;
            border-radius: 18px;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            transition: .25s;
        }

        .upload-box:hover {
            border-color: #0d6efd;
            color: #0d6efd;
        }

        .upload-box i {
            font-size: 40px;
        }

        .upload-box span {
            margin-top: 10px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <!-- TU SIDEBAR -->
    <%- include('./components/navbarAdmin') %>

        <div class="main-content">

            <div class="topbar">
                <h1 class="title">Administrar Carousel</h1>
            </div>

            <div class="grid-upload" id="contenedorCarousel">

                <!-- botón upload tipo Antd -->
                <div class="upload-box" onclick="seleccionarImagen()">
                    <i class="bi bi-plus-lg"></i>
                    <span>Upload</span>
                </div>

            </div>

            <input type="file" id="inputImagen" hidden accept="image/*">

        </div>

        <script>
            async function obtenerImagenes() {
                try {
                    const response = await fetch('/carousel')
                    const data = await response.json()

                    const contenedor = document.getElementById('contenedorCarousel')

                    contenedor.innerHTML = `
            <div class="upload-box" onclick="seleccionarImagen()">
                <i class="bi bi-plus-lg"></i>
                <span>Upload</span>
            </div>
        `

                    data.forEach(item => {

                        contenedor.innerHTML += `
            <div class="card-img">

                <img src="${item.imagen_url}" alt="banner">

                <div class="overlay">
                    <button class="btn-circle btn-edit"
                        onclick="editarImagen(${item.id})">
                        <i class="bi bi-pencil-fill"></i>
                    </button>

                    <button class="btn-circle btn-delete"
                        onclick="eliminarImagen(${item.id})">
                        <i class="bi bi-trash-fill"></i>
                    </button>
                </div>

               

            </div>
            `
                    })

                } catch (error) {
                    console.log(error)
                }
            }

            function seleccionarImagen() {
                document.getElementById('inputImagen').click()
            }

            document.getElementById('inputImagen').addEventListener('change', async function () {

                const archivo = this.files[0]
                if (!archivo) return

                const formData = new FormData()
                formData.append('imagen', archivo)

                const response = await fetch('/carousel', {
                    method: 'POST',
                    body: formData
                })

                const data = await response.json()

                alert(data.msg || 'Imagen subida')

                obtenerImagenes()
            })

            let idEditar = null

            function editarImagen(id) {
                idEditar = id
                document.getElementById('inputImagen').click()
            }

            document.getElementById('inputImagen').addEventListener('change', async function () {

                const archivo = this.files[0]
                if (!archivo) return

                const formData = new FormData()
                formData.append('imagen', archivo)

                let url = '/carousel'
                let method = 'POST'

                // si viene idEditar = editar
                if (idEditar) {
                    url = '/carousel/' + idEditar
                    method = 'PUT'
                }

                const response = await fetch(url, {
                    method,
                    body: formData
                })

                const data = await response.json()

                alert(data.msg || 'Proceso completado')

                // reset
                idEditar = null
                this.value = ''

                obtenerImagenes()
            })

            function eliminarImagen(id) {

                const confirmar = confirm('¿Eliminar imagen?')
                if (!confirmar) return

                fetch('/carousel/' + id, {
                    method: 'DELETE'
                })
                    .then(res => res.json())
                    .then(data => {
                        alert(data.msg)
                        obtenerImagenes()
                    })
            }

            obtenerImagenes()

        </script>

</body>

</html>