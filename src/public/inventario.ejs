<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="shortcut icon" href="img/favicon.png" sizes="150x150" />
    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="css/inventario.css">
    <link rel="stylesheet" href="css/navbar-admin.css">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css"
        integrity="sha384-b6lVK+yci+bfDmaY1u0zE8YYJt0TZxLEAFyYSLHId4xoVvsrQu3INevFKo+Xir8e" crossorigin="anonymous">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/footer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100&family=Quicksand&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-aFq/bzH65dt+w6FI2ooMVUpc+21e0SRygnTpmBvdBgSdnuTN7QbdgL+OapgHtvPp" crossorigin="anonymous">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <script src="https://kit.fontawesome.com/5210f6d31f.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    <title>Inventario</title>

</head>

<body>

    <%- include('./components/navbarAdmin') %>

        <div class="container container-custom">

            <!-- BLOQUE SUPERIOR -->
            <div class="inventario-header">

                <!-- TÍTULO -->
                <div class="inventario-title">
                    Inventario
                </div>

                <!-- BOTÓN -->
                <form id="uploadForm" class="inventario-actions">
                    <input type="file" id="excelInput" name="excel" hidden>

                    <button type="button" id="uploadBtn" class="progress-btn">
                        <span class="btn-text">
                            <i class="bi bi-file-earmark-excel"></i> Cargar Excel
                        </span>
                        <span class="progress-fill"></span>
                    </button>
                </form>

            </div>

            <!--Buscador en tiempo real-->
            <div class="row mb-3 align-items-center">
                <div class="col-md-6">
                    <input type="text" id="searchInput" class="form-control"
                        placeholder="Buscar producto, marca o descripción...">
                </div>

                <div class="col-auto">
                    <button class="btn btn-primary" id="openModalBtn">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
            </div>

            <!-- TABLA EN BLOQUE SEPARADO -->
            <div class="table-wrapper">
                <div class="table-responsive">
                    <table class="table align-middle table-hover">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Descripción</th>
                                <th>Cantidad</th>
                                <th>Precio Público</th>
                                <th>Precio Descuento</th>
                                <th>Marca</th>
                                <th>Código de barras</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (data && data.length> 0) { %>
                                <% data.forEach(item=> { %>
                                    <tr>
                                        <td class="fw-semibold editable" data-id="<%= item.id %>" data-field="producto">
                                            <%= item.producto %>
                                        </td>
                                        <td class="editable" data-id="<%= item.id %>" data-field="descripcion">
                                            <%= item.descripcion %>
                                        </td>
                                        <td class="editable" data-id="<%= item.id %>" data-field="cantidad">
                                            <%= item.cantidad %>
                                        </td>
                                        <td class="editable" data-id="<%= item.id %>" data-field="precio_publico">$<%=
                                                item.precio_publico %>
                                        </td>

                                        <td class="editable" data-id="<%= item.id %>" data-field="precio_descuento">
                                            <% if (item.precio_descuento) { %>
                                                <span class="badge badge-descuento">
                                                    $<%= item.precio_descuento %>
                                                </span>
                                                <% } else { %>
                                                    <span class="text-muted">N/A</span>
                                                    <% } %>
                                        </td>

                                        <td class="editable" data-id="<%= item.id %>" data-field="marca">
                                            <%= item.marca %>
                                        </td>
                                        <td class="editable" data-id="<%= item.id %>" data-field="codigo_barras">
                                            <%= item.codigo_barras %>
                                        </td>
                                        <td class="text-center acciones">
                                            <i class="bi bi-trash text-danger delete-btn" title="Eliminar"
                                                data-id="<% item.id %>"></i>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7" class="text-center text-muted">
                                                    No hay productos en el inventario
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!--Modal popConfirm-->
            <div id="confirmModal" class="confirm-modal hidden">
                <div class="confirm-box">
                    <p id="confirmText">¿Estás seguro?</p>
                    <div class="confirm-actions">
                        <button id="confirmYes" class="btn btn-danger btn-sm">Sí</button>
                        <button id="confirmNo" class="btn btn-secondary btn-sm">Cancelar</button>
                    </div>
                </div>
            </div>

           
            <!-- MODAL AGREGAR PRODUCTO -->
            <div class="modal fade" id="modalProducto" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">

                        <div class="modal-header">
                            <h5 class="modal-title">Agregar producto</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            <form id="formProducto">

                                <input type="text" name="producto" class="form-control mb-2" placeholder="Producto"
                                    required>
                                <input type="text" name="descripcion" class="form-control mb-2"
                                    placeholder="Descripción">

                                <input type="number" name="cantidad" class="form-control mb-2" placeholder="Cantidad"
                                    required>

                                <input type="number" step="0.01" name="precio_publico" class="form-control mb-2"
                                    placeholder="Precio público" required>

                                <input type="number" step="0.01" name="precio_descuento" class="form-control mb-2"
                                    placeholder="Precio descuento">

                                <input type="text" name="marca" class="form-control mb-2" placeholder="Marca">

                                <input type="text" name="codigo_barras" class="form-control mb-2"
                                    placeholder="Código de barras">

                                <button type="submit" class="btn btn-success w-100">
                                    Guardar
                                </button>

                            </form>
                        </div>

                    </div>
                </div>
            </div>

        </div>
        <script src="script/inventario.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</body>

</html>